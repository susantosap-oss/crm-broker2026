// ---------------- LOGIN ----------------
function checkLogin(email){
  try{
    email = (email || '').toString().trim();
    if(!email) return { success:false, message:'Email kosong.' };

    const sheet = getLoginSheet();
    if(!sheet) return { success:false, message:'Sheet BrokerDB tidak ditemukan.' };

    const last = sheet.getLastRow();
    if(last < 2) return { success:false, message:'Tidak ada data broker.' };

    const rows = sheet.getRange(2,1,last-1,2).getValues();
    const map = {};
    rows.forEach(r => {
      const em = (r[0]||'').toString().toLowerCase();
      const nm = (r[1]||'');
      if (em) map[em] = nm;
    });

    const eLow = email.toLowerCase();
    if (map[eLow]) return { success:true, email:eLow, nama:map[eLow] };

    return { success:false, message:'Email tidak terdaftar.' };

  } catch(err){
    Logger.log('checkLogin error: ' + err);
    return { success:false, message:'Server error saat login.' };
  }
}

