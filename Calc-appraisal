// 2. Generate PDF
// ========================
function generateAppraisalPdf(data, lang = 'id', sendEmail = false) {
  try {
    if(!data) throw new Error("Data appraisal kosong.");
    data.tanggal = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd-MM-yyyy");


    // Sanitasi dan fallback formatting
    const safeStr = (val)=> val!==undefined && val!==null? val.toString() : '-';

    data.harga_wajar_max_str   = safeStr(data.harga_wajar_max_str   || formatRupiah(data.harga_wajar_max   || 0));
    data.harga_wajar_dasar_str = safeStr(data.harga_wajar_dasar_str || formatRupiah(data.harga_wajar_dasar || 0));
    data.estimasi_harga_jual_str = safeStr(data.estimasi_harga_jual_str || formatRupiah(data.estimasi_harga_jual || 0));
    data.biaya_agen_str = safeStr(data.biaya_agen_str || formatRupiah(data.biaya_agen || 0));
    data.total_biaya_str = safeStr(data.total_biaya_str || formatRupiah(data.total_biaya || 0));
    data.nett_penjualan_str = safeStr(data.nett_penjualan_str || formatRupiah(data.nett_penjualan || 0));
    data.fee_agen_pct = data.fee_agen_pct !== undefined ? data.fee_agen_pct : 0;

    // Insert tambahan bahasa ke template
    data.lang = lang;

    // Load template HTML
   // Pilih template berdasarkan bahasa
      const templateName = (lang === 'en') ? 'pdf_template_en' : 'pdf_template_id';
      const tpl = HtmlService.createTemplateFromFile(templateName);

    tpl.data = data;

    // Render HTML
    const html = tpl.evaluate().getContent();

    // ==========================
// Convert HTML → PDF
// ==========================

// Format tanggal ddMMyy
const dateStr = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "ddMMyy");

// Singkatkan alamat jika terlalu panjang
let alamatShort = (data.alamat_properti || data.alamat || "Properti").toString().trim();
if (alamatShort.length > 40) {
  alamatShort = alamatShort.substring(0, 40) + "...";
}

// Susun nama file final
const newFileName = sanitizeFilename(
  (data.nama_broker || "Broker") + " - " +
  (data.tipe_transaksi || "Transaksi") + " - " +
  alamatShort + " - " +
  dateStr +
  (lang === 'en' ? "_EN" : "_ID") +
  ".pdf"
);

// Buat PDF blob
const blob = Utilities
  .newBlob(html, "text/html", "appraisal.html")
  .getAs("application/pdf")
  .setName(newFileName);


    // Folder utama
    let masterIter = DriveApp.getFoldersByName("Laporan Apraisal Mansion");
    const masterFolder = masterIter.hasNext() ? masterIter.next() : DriveApp.createFolder("Laporan Apraisal Mansion");

    // Subfolder tanggal
    const todayStr = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd-MM-yy");
    let folderIter = masterFolder.getFoldersByName("Laporan Apraisal " + todayStr);
    const subFolder = folderIter.hasNext() ? folderIter.next() : masterFolder.createFolder("Laporan Apraisal " + todayStr);

    // Simpan file
    const file = subFolder.createFile(blob);

    // Email jika diminta
    if (sendEmail && data.email) {
      try {
        MailApp.sendEmail({
          to: data.email,
          subject: (lang === 'en' ? "Property Appraisal Report - " : "Laporan Appraisal Properti - ") + safeStr(data.alamat_properti),
          body: lang === 'en'
            ? "Here is your attached property appraisal report."
            : "Berikut terlampir laporan appraisal properti Anda.",
          attachments: [file.getAs(MimeType.PDF)]
        });
      } catch(e) { Logger.log("Email gagal dikirim: " + e); }
    }

    // Return link PDF
    return { url: file.getUrl(), name: file.getName() };

  } catch(e) {
    Logger.log("generateAppraisalPdf error: " + e);
    throw new Error("Gagal membuat PDF: " + e.message);
  }
}

function sanitizeFilename(name){ return name.replace(/[\\\/\:\*\?\"\<\>\|]/g,"_"); }
function formatRupiah(num){ if(isNaN(num)) num=0; return 'Rp '+Number(num).toLocaleString('id-ID'); }

