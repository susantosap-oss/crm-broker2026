// ========================
// 1. Hitung Appraisal
// ========================
function hitungAppraisal(form) {
  try {
    if (!form || typeof form !== 'object') return { error: 'Form data tidak valid.' };

    const get = (keys, def) => {
      for (let k of keys) if (form[k] !== undefined && form[k] !== null) return form[k];
      return def;
    };

    const alamat_properti = get(['alamat_properti','alamat_properti'], '');
    const tipe_properti_raw = String(get(['tipe_properti','tipeProperti'], '') || '');
    const tipe_transaksi_raw = String(get(['tipe_transaksi','tipeTransaksi'], 'Jual') || 'Jual');
    const luas_tanah = parseFloat(get(['luas_tanah','luasTanah'], 0)) || 0;
    const luas_bangunan = parseFloat(get(['luas_bangunan','luasBangunan'], 0)) || 0;
    const harga_tanah = parseFloat(get(['harga_tanah','hargaTanah'], 0)) || 0;
    const harga_bangunan = parseFloat(get(['harga_bangunan','hargaBangunan'], 0)) || 0;
    const hargaPasarPerM2 = parseFloat(get(['harga_pasar','harga_pasar_per_m2','hargaPasarPerM2'], 0)) || 0;
    const lokasi_score = Math.min(Math.max(parseFloat(get(['skor_lokasi','lokasiScore'], 3)) || 3, 1), 5);
    const feeAgenPct = parseFloat(get(['fee_agen','feeAgen','fee_agen_pct','feeAgenPct'], 0)) || 0;
    const tahun_bangun = get(['tahun_bangun','tahunBangun'], '') || '';
    
    const tipe_properti = tipe_properti_raw.toString();
    const tipe_transaksi = tipe_transaksi_raw.toString().toLowerCase();
    
   

    function mapKoefLokasi(score) {
      const map = { 1:1.0, 2:1.1, 3:1.2, 4:1.35, 5:1.5 };
      return map[score] || 1;
    }
    const koefLokasi = mapKoefLokasi(lokasi_score);

    let hargaWajarDasar = 0;
    if (/tanah/i.test(tipe_properti)) hargaWajarDasar = luas_tanah * harga_tanah;
    else if (/apartemen/i.test(tipe_properti)) hargaWajarDasar = luas_bangunan * (hargaPasarPerM2>0 ? hargaPasarPerM2 : harga_bangunan);
    else hargaWajarDasar = (luas_tanah*harga_tanah)+(luas_bangunan*harga_bangunan);

    const result = {
      nama_broker: get(['nama_broker','namaBroker'], '') || '',
      email: get(['email'], '') || '',
      alamat_properti,
      tipe_properti,
      tipe_transaksi,
      luas_tanah,
      luas_bangunan,
      tahun_bangun: tahun_bangun || '',
      usia_bangunan: tahun_bangun ? (new Date().getFullYear() - Number(tahun_bangun)) : '',
      lokasi_score,
      koef_lokasi: koefLokasi,
      harga_wajar_dasar: hargaWajarDasar
    };

    // === Tambahkan Sertifikat ===
    const sertifikat = get(['sertifikat'], '');
    result.sertifikat = sertifikat;

    let hargaWajarMax = hargaWajarDasar;
    let biayaAgen=0, biayaPph=0, biayaLain=0, totalBiaya=0, estimasiHargaJual=0, nettPenjualan=0, nilaiSewa=0;

    if (/apartemen/i.test(tipe_properti) && tipe_transaksi==='jual') {
      const dasarM2 = (hargaPasarPerM2>0 ? hargaPasarPerM2 : harga_bangunan);
      const hargaWajarDasar_Apt = Math.round(dasarM2*luas_bangunan);
      const totalBiayaPct = feeAgenPct + 2.5 + 1;
      const totalBiaya_Apt = Math.round((totalBiayaPct/100)*hargaWajarDasar_Apt);
      const hargaWajarMax_Apt = hargaWajarDasar_Apt;
      const estimasiHargaJual_Apt = hargaWajarMax_Apt;
      const biayaAgen_Apt = Math.round((feeAgenPct/100)*hargaWajarDasar_Apt);
      const biayaPph_Apt = Math.round(0.025*hargaWajarDasar_Apt);
      const biayaLain_Apt = Math.round(0.01*hargaWajarDasar_Apt);
      const nettPenjualan_Apt = hargaWajarDasar_Apt - totalBiaya_Apt;

      result.harga_wajar_dasar = hargaWajarDasar_Apt;
      result.harga_wajar_max = hargaWajarMax_Apt;
      result.estimasi_harga_jual = estimasiHargaJual_Apt;
      result.biaya_agen = biayaAgen_Apt;
      result.biaya_pph = biayaPph_Apt;
      result.biaya_lain = biayaLain_Apt;
      result.total_biaya = totalBiaya_Apt;
      result.nett_penjualan = nettPenjualan_Apt;
      result.fee_agen_pct = feeAgenPct;

      // formatted
      const formatRupiah = (num)=> 'Rp ' + Number(num).toLocaleString('id-ID');
      result.harga_wajar_dasar_str = formatRupiah(hargaWajarDasar_Apt);
      result.harga_wajar_max_str = formatRupiah(hargaWajarMax_Apt);
      result.estimasi_harga_jual_str = formatRupiah(estimasiHargaJual_Apt);
      result.biaya_agen_str = formatRupiah(biayaAgen_Apt);
      result.biaya_pph_str = formatRupiah(biayaPph_Apt);
      result.biaya_lain_str = formatRupiah(biayaLain_Apt);
      result.total_biaya_str = formatRupiah(totalBiaya_Apt);
      result.nett_penjualan_str = formatRupiah(nettPenjualan_Apt);

      result.generatedAt = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'dd MMMM yyyy HH:mm');
      return result;
    }

    if(tipe_transaksi==='jual' && !/apartemen/i.test(tipe_properti)){
      hargaWajarMax = Math.round(hargaWajarDasar * koefLokasi);
      totalBiaya = Math.round(((feeAgenPct+2.5+1)/100)*hargaWajarMax);
      biayaAgen = Math.round((feeAgenPct/100)*hargaWajarMax);
      biayaPph = Math.round(0.025*hargaWajarMax);
      biayaLain = Math.round(0.01*hargaWajarMax);
      estimasiHargaJual = Math.round(hargaWajarMax+totalBiaya);
      nettPenjualan = Math.round(hargaWajarMax-totalBiaya);

      result.harga_wajar_max = hargaWajarMax;
      result.estimasi_harga_jual = estimasiHargaJual;
      result.biaya_agen = biayaAgen;
      result.biaya_pph = biayaPph;
      result.biaya_lain = biayaLain;
      result.total_biaya = totalBiaya;
      result.nett_penjualan = nettPenjualan;
      result.fee_agen_pct = feeAgenPct;

      const formatRupiah = (num)=> 'Rp ' + Number(num).toLocaleString('id-ID');
      result.harga_wajar_dasar_str = formatRupiah(hargaWajarDasar);
      result.harga_wajar_max_str = formatRupiah(hargaWajarMax);
      result.estimasi_harga_jual_str = formatRupiah(estimasiHargaJual);
      result.biaya_agen_str = formatRupiah(biayaAgen);
      result.biaya_pph_str = formatRupiah(biayaPph);
      result.biaya_lain_str = formatRupiah(biayaLain);
      result.total_biaya_str = formatRupiah(totalBiaya);
      result.nett_penjualan_str = formatRupiah(nettPenjualan);

      result.generatedAt = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'dd MMMM yyyy HH:mm');
      return result;
    }

    // Logika sewa
    // ganti disini untuk % sewa tahunan 
    const sewaPctMap = { 'rumah': 0.03, 'ruko': 0.035, 'apartemen': 0.07, 'gudang': 0.05, 'tanah': 0.02 };
    const sewaPct = sewaPctMap[tipe_properti.toLowerCase()] || 0;
    nilaiSewa = Math.round(hargaWajarMax*sewaPct);
    biayaAgen = Math.round((feeAgenPct/100)*nilaiSewa);
    biayaPph = (String(get(['jenis_pph','jenisPph'], '')).toLowerCase()==='perorangan')?0:Math.round(0.10*nilaiSewa);
    totalBiaya = biayaAgen+biayaPph;
    estimasiHargaJual = Math.round(nilaiSewa+totalBiaya);
    nettPenjualan = Math.round(nilaiSewa-totalBiaya);

    result.nilai_sewa = nilaiSewa;
    result.estimasi_harga_sewa = estimasiHargaJual;
    result.biaya_agen = biayaAgen;
    result.biaya_pph = biayaPph;
    result.total_biaya = totalBiaya;
    result.nett_penjualan = nettPenjualan;
    result.sewa_pct = sewaPct;
    result.fee_agen_pct = feeAgenPct;

    const formatRupiah = (num)=> 'Rp ' + Number(num).toLocaleString('id-ID');
    result.harga_wajar_dasar_str = formatRupiah(hargaWajarDasar);
    result.harga_wajar_max_str = formatRupiah(hargaWajarMax);
    result.estimasi_harga_jual_str = formatRupiah(estimasiHargaJual);
    result.nilai_sewa_str = formatRupiah(nilaiSewa);
    result.biaya_agen_str = formatRupiah(biayaAgen);
    result.biaya_pph_str = formatRupiah(biayaPph);
    result.total_biaya_str = formatRupiah(totalBiaya);
    result.nett_penjualan_str = formatRupiah(nettPenjualan);
    result.generatedAt = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'dd MMMM yyyy HH:mm');
    return result;
    

  } catch(err){
    Logger.log('hitungAppraisal error: '+err);
    return { error: err.toString() };
  }
}

