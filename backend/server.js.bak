/**
 * CRM Broker Properti - GAS Edition
 * Server Entry Point
 * ============================================
 * Google Sheets = Single Source of Truth (SSoT)
 * This server acts as API Provider for:
 *   1. CRM Web App (internal)
 *   2. External Website (public read-only API)
 */

require('dotenv').config();
const express = require('express');
const cors = require('cors');
const helmet = require('helmet');
const morgan = require('morgan');
const path = require('path');

const app = express();
const PORT = process.env.PORT || 3000;

// ── Middleware ─────────────────────────────────────────────
app.use(helmet({ contentSecurityPolicy: false }));
app.use(cors({
  origin: process.env.NODE_ENV === 'production'
    ? [process.env.APP_URL, process.env.WEBSITE_URL]
    : '*',
  credentials: true
}));
app.use(morgan('dev'));
app.use(express.json({ limit: '10mb' }));
app.use(express.urlencoded({ extended: true }));

// ── Static Files (Frontend) ────────────────────────────────
app.use(express.static(path.join(__dirname, '../frontend')));

// ── API Routes ─────────────────────────────────────────────
// Internal CRM API (requires auth)
app.use('/api/v1/auth',     require('./routes/auth.routes'));
app.use('/api/v1/listings', require('./routes/listings.routes'));
app.use('/api/v1/leads',    require('./routes/leads.routes'));
app.use('/api/v1/agents',   require('./routes/agents.routes'));
app.use('/api/v1/whatsapp', require('./routes/whatsapp.routes'));
app.use('/api/v1/media',    require('./routes/media.routes'));
app.use('/api/v1/dashboard',require('./routes/dashboard.routes'));
app.use('/api/v1/captions', require('./routes/captions.routes'));
app.use('/api/v1/tasks',    require('./routes/tasks.routes'));
// Config endpoint
app.get('/api/v1/config/cloudinary', (req, res) => {
  res.json({ success: true, cloudName: process.env.CLOUDINARY_CLOUD_NAME, uploadPreset: process.env.CLOUDINARY_UPLOAD_PRESET || 'crm_unsigned' });
});


// ── PUBLIC API (for external website) ─────────────────────
// Read-only, API key protected — Website pulls data from here
// Rate limit: 60 requests per minute per IP
const publicApiLimiter = require('express-rate-limit')({
  windowMs: 60 * 1000,
  max: 60,
  message: { success: false, message: 'Too many requests. Try again in 1 minute.' },
  standardHeaders: true,
  legacyHeaders: false,
  keyGenerator: (req) => req.headers['x-forwarded-for']?.split(',')[0] || req.ip,
});
app.use('/public/api/v1', publicApiLimiter);
app.use('/public/api/v1',   require('./routes/public.routes'));

// ── Health Check ───────────────────────────────────────────
app.get('/health', (req, res) => {
  res.json({
    status: 'OK',
    app: process.env.APP_NAME,
    timestamp: new Date().toISOString(),
    version: '1.0.0'
  });
});

// ── Global Error Handler (MUST be before SPA fallback) ────
app.use((err, req, res, next) => {
  console.error('[ERROR]', err.stack);
  // Only return JSON for API routes
  if (req.path.startsWith('/api/') || req.path.startsWith('/public/')) {
    return res.status(err.status || 500).json({
      success: false,
      message: err.message || 'Internal Server Error',
      ...(process.env.NODE_ENV === 'development' && { stack: err.stack })
    });
  }
  next(err);
});

// ── SPA Fallback (MUST be after error handler) ─────────────
app.get('*', (req, res) => {
  res.sendFile(path.join(__dirname, '../frontend/index.html'));
});

// ── Auto-migrate: ensure new columns exist in LEADS header ─
async function migrateLeadsHeaders() {
  try {
    const sheetsService = require('./services/sheets.service');
    const { SHEETS, COLUMNS } = require('./config/sheets.config');
    const rows = await sheetsService.getRange(SHEETS.LEADS);
    if (!rows || !rows[0]) return;
    const existingHeaders = rows[0];
    const requiredHeaders = COLUMNS.LEADS;
    let updated = false;
    const newHeaders = [...existingHeaders];
    requiredHeaders.forEach(col => {
      if (!existingHeaders.includes(col)) {
        newHeaders.push(col);
        updated = true;
        console.log(`📊 [Migration] Adding column: ${col}`);
      }
    });
    if (updated) {
      await sheetsService.updateRow(SHEETS.LEADS, 1, newHeaders);
      console.log('✅ LEADS headers migrated');
    }
  } catch (e) {
    console.warn('[Migration] Header migration skipped:', e.message);
  }
}

// ── Start Server ───────────────────────────────────────────
app.listen(PORT, async () => {
  console.log(`\n🏢 CRM Broker Properti - GAS Edition`);
  console.log(`🚀 Server running on http://localhost:${PORT}`);
  console.log(`📊 Google Sheets SSoT connected`);
  console.log(`🌐 Public API: http://localhost:${PORT}/public/api/v1`);
  console.log(`📱 PWA Ready\n`);
  // Run migrations
  await migrateLeadsHeaders();
});

module.exports = app;

// ── Telegram Bot (PR 16) ───────────────────────────────────
if (process.env.TELEGRAM_BOT_TOKEN) {
  require('./telegram-bot');
  console.log('🤖 Telegram Bot aktif');
}
