# ============================================
# CRM Broker Properti - GAS Edition
# Environment Configuration
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=development
APP_NAME="CRM Broker Properti"
APP_URL=http://localhost:3000

# --- JWT Authentication ---
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# --- Google Sheets API (SSoT) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_ID=your_google_spreadsheet_id_here

# --- Cloudinary (Media Storage) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=crm-broker-properti

# --- WhatsApp Integration ---
WA_API_URL=https://api.whatsapp.com
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_access_token
WA_VERIFY_TOKEN=your_webhook_verify_token

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Cache TTL (seconds) ---
CACHE_TTL_LISTINGS=300
CACHE_TTL_LEADS=120

# --- Google Form ---
KOMISI_FORM_URL=https://docs.google.com/forms/d/YOUR_FORM_ID/viewform?embedded=true

# --- Public API ---
PUBLIC_API_KEY=public_readonly_key_for_website_integration
